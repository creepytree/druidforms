{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "noEmit": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "include": ["web/src", "assets/palette.json"]
}
